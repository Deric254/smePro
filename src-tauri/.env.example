# Copy to .env (or export these directly) before running the server.
# None of these are required — every feature except the AI assistant
# works with zero configuration.

# Which AI backend the floating assistant uses. Defaults to nvidia_nim
# (free, no credit card) if unset.
AI_PROVIDER=nvidia_nim   # nvidia_nim | gemini | claude

# --- NVIDIA NIM (free, ~40 requests/min, no credit card) ---
# Get a key at https://build.nvidia.com  (sign up -> open any model -> "Get API Key")
NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro   # any model from build.nvidia.com/models

# --- Google Gemini (free tier: Flash / Flash-Lite, no credit card) ---
# Get a key at https://aistudio.google.com
# NOTE: on the free tier, Google's terms allow using your prompts to
# improve their models. Fine for testing; consider this before sending
# real customer data through it.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Claude (paid, no free tier) ---
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Which notification backend WhatsApp/SMS alerts use. Defaults to
# 'log' (records to the notifications table, no external account needed)
# if unset.
NOTIFICATION_PROVIDER=log   # log | twilio

# --- Twilio (real WhatsApp/SMS delivery) ---
# https://console.twilio.com — for WhatsApp, TWILIO_FROM_NUMBER must be
# WhatsApp-enabled in the Twilio console (separate setup step there).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Payments (Stripe / M-Pesa) ---
# Default provider when the frontend doesn't specify one explicitly.
PAYMENT_PROVIDER=stripe   # stripe | mpesa

# Stripe — https://dashboard.stripe.com/apikeys (test mode keys start
# with sk_test_ / whsec_test_ — use those until you're ready to go live)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# M-Pesa (Safaricom Daraja) — https://developer.safaricom.co.ke
# Sandbox by default; set MPESA_ENV=production only with real,
# go-live-approved production credentials.
MPESA_ENV=sandbox   # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a real, publicly-reachable HTTPS URL Safaricom can call back —
# a bare 127.0.0.1 URL only works if you've tunneled it (e.g. ngrok)
# during local development.
MPESA_CALLBACK_URL=

# Vendor-issued license key redemption (see vendor-authority/ and
# vendor_license.rs) — a separate, simpler mechanism from the
# subscription billing above. If you (the vendor) run a
# vendor_authority server to issue and device-lock license keys to your
# customers, point each customer's install at it here. Optional — the
# app works fully without this set; only POST /license/vendor/redeem
# needs it.
VENDOR_LICENSE_URL=
